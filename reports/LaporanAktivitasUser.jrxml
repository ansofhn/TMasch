<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="LaporanAktivitasUser"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="a1b2c3d4-0004-0004-0004-000000000004">

    <queryString>
        <![CDATA[
        SELECT
            u.full_name                                                             AS nama_user,
            r.name                                                                  AS role,
            u.department                                                            AS dept,
            (SELECT COUNT(*) FROM tickets t
             WHERE t.created_by = u.id)                                            AS tiket_dibuat,
            (SELECT COUNT(*) FROM tickets t
             WHERE t.created_by = u.id
             AND t.status_id = (SELECT id FROM statuses WHERE name = 'RESOLVED' LIMIT 1))
                                                                                   AS tiket_selesai,
            (SELECT COUNT(*) FROM tickets t
             WHERE t.created_by = u.id
             AND t.status_id NOT IN (
                 SELECT id FROM statuses WHERE name IN ('RESOLVED','CLOSED')
             ))                                                                     AS tiket_aktif,
            COALESCE(ROUND((SELECT AVG(TIMESTAMPDIFF(MINUTE, t.created_at, t.resolved_at)) / 60.0
             FROM tickets t
             WHERE t.assigned_to = u.id
             AND t.resolved_at IS NOT NULL), 1), 0)                                AS avg_jam_resolusi
        FROM users u
        JOIN roles r ON u.role_id = r.id
        ORDER BY tiket_dibuat DESC
        ]]>
    </queryString>

    <field name="nama_user"        class="java.lang.String"/>
    <field name="role"             class="java.lang.String"/>
    <field name="dept"             class="java.lang.String"/>
    <field name="tiket_dibuat"     class="java.lang.Long"/>
    <field name="tiket_selesai"    class="java.lang.Long"/>
    <field name="tiket_aktif"      class="java.lang.Long"/>
    <field name="avg_jam_resolusi" class="java.lang.Double"/>

    <!-- Title -->
    <title>
        <band height="70">
            <rectangle><reportElement x="0" y="0" width="535" height="60" backcolor="#1E3A5F" mode="Opaque"/></rectangle>
            <staticText>
                <reportElement x="10" y="5" width="515" height="28" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="15" isBold="true"/></textElement>
                <text><![CDATA[LAPORAN AKTIVITAS USER — T-Masch]]></text>
            </staticText>
            <staticText>
                <reportElement x="10" y="35" width="515" height="18" forecolor="#93C5FD"/>
                <textElement verticalAlignment="Middle"><font size="9"/></textElement>
                <text><![CDATA[Ringkasan tiket yang dibuat dan diselesaikan per user aktif]]></text>
            </staticText>
        </band>
    </title>

    <!-- Column Header -->
    <columnHeader>
        <band height="28">
            <rectangle><reportElement x="0" y="0" width="535" height="28" backcolor="#334155" mode="Opaque"/></rectangle>
            <staticText><reportElement x="0"   y="0" width="120" height="28" forecolor="#FFFFFF"/><textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Nama User]]></text></staticText>
            <staticText><reportElement x="122" y="0" width="55"  height="28" forecolor="#FFFFFF"/><textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Role]]></text></staticText>
            <staticText><reportElement x="179" y="0" width="75"  height="28" forecolor="#FFFFFF"/><textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Dept/Kelas]]></text></staticText>
            <staticText><reportElement x="256" y="0" width="45"  height="28" forecolor="#60A5FA"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Dibuat]]></text></staticText>
            <staticText><reportElement x="303" y="0" width="45"  height="28" forecolor="#6EE7B7"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Selesai]]></text></staticText>
            <staticText><reportElement x="350" y="0" width="40"  height="28" forecolor="#FCD34D"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Aktif]]></text></staticText>
            <staticText><reportElement x="392" y="0" width="143" height="28" forecolor="#C084FC"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[Avg Resolusi (jam)]]></text></staticText>
        </band>
    </columnHeader>

    <!-- Detail -->
    <detail>
        <band height="24">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="23" backcolor="#F8FAFC" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <line><reportElement x="0" y="23" width="535" height="1" forecolor="#E2E8F0"/></line>
            <textField><reportElement x="0"   y="0" width="120" height="23"/><textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{nama_user}]]></textFieldExpression></textField>
            <textField><reportElement x="122" y="0" width="55"  height="23"/><textElement verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{role}]]></textFieldExpression></textField>
            <textField><reportElement x="179" y="0" width="75"  height="23"/><textElement verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{dept} != null ? $F{dept} : "-"]]></textFieldExpression></textField>
            <textField><reportElement x="256" y="0" width="45"  height="23"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{tiket_dibuat}]]></textFieldExpression></textField>
            <textField><reportElement x="303" y="0" width="45"  height="23"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{tiket_selesai}]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="0" width="40"  height="23"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{tiket_aktif}]]></textFieldExpression></textField>
            <textField><reportElement x="392" y="0" width="143" height="23"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{avg_jam_resolusi} + " jam"]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="400" height="20" forecolor="#94A3B8"/><textElement verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[T-Masch — Laporan Aktivitas User]]></text></staticText>
            <textField><reportElement x="435" y="0" width="100" height="20" forecolor="#94A3B8"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA["Hal. " + $V{PAGE_NUMBER}]]></textFieldExpression></textField>
        </band>
    </pageFooter>

</jasperReport>
